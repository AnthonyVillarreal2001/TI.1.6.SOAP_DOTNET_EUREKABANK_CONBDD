<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="_02.CLIMOV.Vista.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0a1428">

    <Grid RowDefinitions="Auto,*">

        <!-- Overlay oscuro -->
        <BoxView Grid.Row="0" Grid.RowSpan="2" Color="#000000" Opacity="0.4"/>

        <!-- Header Glass Effect -->
        <Grid Grid.Row="0" Padding="20,12" RowSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.Background>
                <SolidColorBrush Color="#0a3d62"/>
            </Grid.Background>

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Label Text="🏦" FontSize="28" VerticalOptions="Center"/>
                <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                    <Label Text="EurekaBank" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="Tu banco, tu equipo." FontSize="11" TextColor="#e0e0e0"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Grid>

        <!-- Login Form Container -->
        <ScrollView Grid.Row="1" VerticalOptions="Center" Padding="20">
            <VerticalStackLayout HorizontalOptions="Center" Spacing="0">

                <!-- White Card -->
                <Frame CornerRadius="20" BackgroundColor="White" Padding="30"
                       WidthRequest="340" MaximumWidthRequest="380" HasShadow="True">

                    <VerticalStackLayout Spacing="20">

                        <!-- Icon -->
                        <Label Text="👤" FontSize="60" HorizontalOptions="Center"
                               TextColor="#0a3d62"/>

                        <!-- Title -->
                        <Label Text="Ingreso al Sistema" FontSize="24" FontAttributes="Bold"
                               HorizontalOptions="Center" TextColor="#0a3d62"/>

                        <!-- Usuario Field -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Usuario" FontSize="12" FontAttributes="Bold"
                                   TextColor="#0a3d62"/>
                            <Entry x:Name="EntryUsuario" Placeholder="Ej: monster"
                                   PlaceholderColor="#999" FontSize="14"
                                   BackgroundColor="#f5f5f5" TextColor="#333"/>
                        </VerticalStackLayout>

                        <!-- Password Field -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Contraseña" FontSize="12" FontAttributes="Bold"
                                   TextColor="#0a3d62"/>
                            <Entry x:Name="EntryPassword" Placeholder="Ingrese su contraseña"
                                   PlaceholderColor="#999" FontSize="14" IsPassword="True"
                                   BackgroundColor="#f5f5f5" TextColor="#333"/>
                        </VerticalStackLayout>

                        <!-- Button -->
                        <Button x:Name="BtnLogin" Text="INGRESAR"
                                BackgroundColor="#e67e22" TextColor="White"
                                FontAttributes="Bold" FontSize="16" CornerRadius="25"
                                Padding="20,12" Clicked="OnLoginClicked" Margin="0,10,0,0"/>

                        <!-- Loading -->
                        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False"
                                         IsVisible="False" Color="#e67e22"/>

                    </VerticalStackLayout>
                </Frame>

                <!-- Footer -->
                <Label Text="Desarrollado por Ariel R. y Anthony V." FontSize="10"
                       TextColor="#ffffff" HorizontalOptions="Center" Margin="0,30,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>