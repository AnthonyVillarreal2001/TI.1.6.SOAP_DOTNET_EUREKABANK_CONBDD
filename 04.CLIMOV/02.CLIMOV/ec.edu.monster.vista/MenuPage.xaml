<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="_02.CLIMOV.Vista.MenuPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0a1428">

    <Grid RowDefinitions="Auto,*" ColumnSpacing="0" RowSpacing="0">

        <!-- Overlay oscuro -->
        <BoxView Grid.Row="0" Grid.RowSpan="2" Color="#000000" Opacity="0.3"/>

        <!-- Header Glass Effect -->
        <Grid Grid.Row="0" Padding="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid.Background>
                <SolidColorBrush Color="#0a3d62"/>
            </Grid.Background>

            <!-- Left: Logo & Title -->
            <HorizontalStackLayout Grid.Column="0" Spacing="12" VerticalOptions="Center">
                <Label Text="🏦" FontSize="28" VerticalOptions="Center"/>
                <Label Text="EurekaBank" FontSize="20" FontAttributes="Bold"
                       TextColor="White" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Right: User & Logout -->
            <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                <Label Text="👤" FontSize="18" TextColor="White" VerticalOptions="Center"/>
                <Label x:Name="LblUsuario" Text="M" FontSize="14" FontAttributes="Bold"
                       TextColor="White" VerticalOptions="Center"/>
                <Button Text="⏻" Clicked="OnCerrarSesionClicked"
                        BackgroundColor="Transparent" TextColor="White"
                        FontSize="18" Padding="8,4" CornerRadius="20"/>
            </HorizontalStackLayout>
        </Grid>

        <!-- Content Area with Cards -->
        <ScrollView Grid.Row="1" Padding="16">
            <VerticalStackLayout Spacing="14" Padding="0">

                <!-- Card 1: Consulta Movimientos -->
                <Frame CornerRadius="16" BorderColor="White" BackgroundColor="#ffffff"
                       HasShadow="True" Padding="0">
                    <Grid RowDefinitions="Auto,Auto" x:Name="CardMovimientos">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardMovimientosClicked"/>
                        </Grid.GestureRecognizers>

                        <!-- Header -->
                        <Grid Grid.Row="0" Padding="20" HeightRequest="70">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0a3d62" Offset="0.0"/>
                                    <GradientStop Color="#0c2d48" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Grid.Background>
                            <HorizontalStackLayout Spacing="14" VerticalOptions="Center">
                                <Label Text="📊" FontSize="36"/>
                                <Label Text="Consultar Movimientos" FontSize="15"
                                       FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <!-- Form -->
                        <StackLayout Grid.Row="1" x:Name="FormMovimientos" IsVisible="False"
                                    Padding="16" Spacing="10">
                            <Label Text="Número de Cuenta" FontSize="12" FontAttributes="Bold"
                                   TextColor="#0a3d62"/>
                            <Entry Placeholder="Ej: 1234567890" PlaceholderColor="#ccc"/>
                            <Button Text="Ver Movimientos" BackgroundColor="#e67e22"
                                    TextColor="White" CornerRadius="20" Clicked="OnConsultarMovimientosClicked"/>
                        </StackLayout>
                    </Grid>
                </Frame>

                <!-- Card 2: Depósito -->
                <Frame CornerRadius="16" BorderColor="White" BackgroundColor="#ffffff"
                       HasShadow="True" Padding="0">
                    <Grid RowDefinitions="Auto,Auto" x:Name="CardDeposito">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardDepositoClicked"/>
                        </Grid.GestureRecognizers>

                        <Grid Grid.Row="0" Padding="20" HeightRequest="70">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0a3d62" Offset="0.0"/>
                                    <GradientStop Color="#0c2d48" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Grid.Background>
                            <HorizontalStackLayout Spacing="14" VerticalOptions="Center">
                                <Label Text="💵" FontSize="36"/>
                                <Label Text="Depósito" FontSize="15" FontAttributes="Bold"
                                       TextColor="White" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <StackLayout Grid.Row="1" x:Name="FormDeposito" IsVisible="False"
                                    Padding="16" Spacing="10">
                            <Label Text="Cuenta Destino" FontSize="12" FontAttributes="Bold"
                                   TextColor="#0a3d62"/>
                            <Entry Placeholder="Número de cuenta"/>
                            <Label Text="Importe (USD)" FontSize="12" FontAttributes="Bold"
                                   TextColor="#0a3d62"/>
                            <Entry Placeholder="0.00" Keyboard="Numeric"/>
                            <Button Text="Depositar" BackgroundColor="#e67e22"
                                    TextColor="White" CornerRadius="20" Clicked="OnDepositoClicked"/>
                        </StackLayout>
                    </Grid>
                </Frame>

                <!-- Card 3: Retiro -->
                <Frame CornerRadius="16" BorderColor="White" BackgroundColor="#ffffff"
                       HasShadow="True" Padding="0">
                    <Grid RowDefinitions="Auto,Auto" x:Name="CardRetiro">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardRetiroClicked"/>
                        </Grid.GestureRecognizers>

                        <Grid Grid.Row="0" Padding="20" HeightRequest="70">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0a3d62" Offset="0.0"/>
                                    <GradientStop Color="#0c2d48" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Grid.Background>
                            <HorizontalStackLayout Spacing="14" VerticalOptions="Center">
                                <Label Text="💸" FontSize="36"/>
                                <Label Text="Retiro" FontSize="15" FontAttributes="Bold"
                                       TextColor="White" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <StackLayout Grid.Row="1" x:Name="FormRetiro" IsVisible="False"
                                    Padding="16" Spacing="10">
                            <Label Text="Cuenta Origen" FontSize="12" FontAttributes="Bold"
                                   TextColor="#0a3d62"/>
                            <Entry Placeholder="Número de cuenta"/>
                            <Label Text="Importe (USD)" FontSize="12" FontAttributes="Bold"
                                   TextColor="#0a3d62"/>
                            <Entry Placeholder="0.00" Keyboard="Numeric"/>
                            <Button Text="Retirar" BackgroundColor="#e67e22"
                                    TextColor="White" CornerRadius="20" Clicked="OnRetiroClicked"/>
                        </StackLayout>
                    </Grid>
                </Frame>

                <!-- Card 4: Transferencia -->
                <Frame CornerRadius="16" BorderColor="White" BackgroundColor="#ffffff"
                       HasShadow="True" Padding="0">
                    <Grid RowDefinitions="Auto,Auto" x:Name="CardTransferencia">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardTransferenciaClicked"/>
                        </Grid.GestureRecognizers>

                        <Grid Grid.Row="0" Padding="20" HeightRequest="70">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0a3d62" Offset="0.0"/>
                                    <GradientStop Color="#0c2d48" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Grid.Background>
                            <HorizontalStackLayout Spacing="14" VerticalOptions="Center">
                                <Label Text="🔄" FontSize="36"/>
                                <Label Text="Transferencia" FontSize="15" FontAttributes="Bold"
                                       TextColor="White" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <StackLayout Grid.Row="1" x:Name="FormTransferencia" IsVisible="False"
                                    Padding="16" Spacing="10">
                            <Label Text="Cuenta Origen" FontSize="12" FontAttributes="Bold"
                                   TextColor="#0a3d62"/>
                            <Entry Placeholder="Número de cuenta"/>
                            <Label Text="Cuenta Destino" FontSize="12" FontAttributes="Bold"
                                   TextColor="#0a3d62"/>
                            <Entry Placeholder="Número de cuenta"/>
                            <Label Text="Importe (USD)" FontSize="12" FontAttributes="Bold"
                                   TextColor="#0a3d62"/>
                            <Entry Placeholder="0.00" Keyboard="Numeric"/>
                            <Button Text="Transferir" BackgroundColor="#e67e22"
                                    TextColor="White" CornerRadius="20" Clicked="OnTransferenciaClicked"/>
                        </StackLayout>
                    </Grid>
                </Frame>

                <!-- Footer -->
                <Label Text="Desarrollado por Ariel R. y Anthony V. | EurekaBank © 2025"
                       FontSize="10" TextColor="#ffffff" HorizontalOptions="Center" Margin="0,20"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
