@{
    Layout = null;
    var usuario = (string?)ViewBag.Usuario ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Panel · EurekaBank</title>
    <link rel="stylesheet" href="~/css/bank-theme.css" />
    <style>
            /* Asegurar que el footer quede abajo */
            html, body {
                height: 100%;
                margin: 0;
                display: flex;
                flex-direction: column;
            }

            .main-container {
                flex: 1;
            }

            .bank-footer {
                background: rgba(10, 61, 66, 0.9);
                backdrop-filter: blur(8px);
                text-align: center;
                padding: 1rem;
                color: rgba(255,255,255,0.8);
                font-size: 0.8rem;
                border-top: 1px solid rgba(255,255,255,0.2);
                margin-top: 2rem;
            }

                .bank-footer p {
                    margin: 0;
                    letter-spacing: 0.5px;
                }

                .bank-footer span {
                    color: var(--secondary);
                    font-weight: 600;
                }
    </style>
</head>
<body>

    <div class="bank-header">
        <div class="logo-area">
            <img src="~/img/logo-ldu.png" class="logo-img" alt="Logo" />
            <h1>EurekaBank</h1>
        </div>
        <div class="user-area">
            <div class="user-badge">
                <div class="user-avatar">
                    <img src="~/img/monster.jpg" alt="Monster Avatar"
                         onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex';" />
                    <span style="display: none;">M</span>
                </div>
                <span>@usuario</span>
            </div>
            <a asp-controller="Home" asp-action="Logout" class="btn-logout" id="logoutBtn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                Cerrar Sesión
            </a>
        </div>
    </div>

    <div class="main-container">
        <div class="operations-grid">

            <!-- Tarjeta 1: Consulta de Movimientos -->
            <div class="operation-card" data-card="1">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" /></svg>
                </div>
                <div class="card-title">Consulta de Movimientos</div>
                <div class="card-form">
                    <form asp-controller="Movimientos" asp-action="Index" method="get">
                        <div class="form-group">
                            <label>Número de cuenta</label>
                            <input type="text" name="cuenta" class="input-modern" placeholder="Ej: 00100001" required />
                        </div>
                        <button type="submit" class="btn-modern">Ver movimientos</button>
                    </form>
                </div>
            </div>

            <!-- Tarjeta 2: Depósito -->
            <div class="operation-card" data-card="2">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" /><circle cx="12" cy="12" r="3" /></svg>
                </div>
                <div class="card-title">Depósito</div>
                <div class="card-form">
                    <form asp-controller="Home" asp-action="Operacion" method="post">
                        <input type="hidden" name="action" value="deposito" />
                        <div class="form-group"><label>Cuenta destino</label><input type="text" name="cuenta" class="input-modern" required /></div>
                        <div class="form-group"><label>Importe (USD)</label><input type="number" step="0.01" name="importe" class="input-modern" required /></div>
                        <button type="submit" class="btn-modern">Depositar</button>
                    </form>
                </div>
            </div>

            <!-- Tarjeta 3: Retiro -->
            <div class="operation-card" data-card="3">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M17 9V7a5 5 0 0 0-10 0v2M5 9h14l-1 12H6L5 9z" /><circle cx="12" cy="16" r="1" /><path d="M9 13h6" /></svg>
                </div>
                <div class="card-title">Retiro</div>
                <div class="card-form">
                    <form asp-controller="Home" asp-action="Operacion" method="post">
                        <input type="hidden" name="action" value="retiro" />
                        <div class="form-group"><label>Cuenta origen</label><input type="text" name="cuenta" class="input-modern" required /></div>
                        <div class="form-group"><label>Importe (USD)</label><input type="number" step="0.01" name="importe" class="input-modern" required /></div>
                        <button type="submit" class="btn-modern">Retirar</button>
                    </form>
                </div>
            </div>

            <!-- Tarjeta 4: Transferencia -->
            <div class="operation-card" data-card="4">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M4 17l4 4 4-4M12 19V5M20 7l-4-4-4 4M8 5h8" /></svg>
                </div>
                <div class="card-title">Transferencia</div>
                <div class="card-form">
                    <form asp-controller="Home" asp-action="Operacion" method="post">
                        <input type="hidden" name="action" value="transferencia" />
                        <div class="form-group"><label>Cuenta origen</label><input type="text" name="cuentaOrigen" class="input-modern" required /></div>
                        <div class="form-group"><label>Cuenta destino</label><input type="text" name="cuentaDestino" class="input-modern" required /></div>
                        <div class="form-group"><label>Importe (USD)</label><input type="number" step="0.01" name="importe" class="input-modern" required /></div>
                        <button type="submit" class="btn-modern">Transferir</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <footer class="bank-footer">
        <p>Desarrollado por <span>Ariel R.</span> y <span>Anthony V.</span> | EurekaBank © 2025</p>
    </footer>

    <script>
            (function() {
                const cards = document.querySelectorAll('.operation-card');

                function closeAllCards() {
                    cards.forEach(card => {
                        card.classList.remove('active');
                    });
                }

                function openCard(card) {
                    closeAllCards();
                    card.classList.add('active');
                }

                cards.forEach(card => {
                    // El header incluye icono y título
                    const header = card.querySelector('.card-icon, .card-title');
                    header.addEventListener('click', (e) => {
                        e.stopPropagation();
                        if (card.classList.contains('active')) {
                            card.classList.remove('active');
                        } else {
                            openCard(card);
                        }
                    });

                    // Evitar que el clic dentro del formulario cierre la card
                    const form = card.querySelector('.card-form');
                    if (form) {
                        form.addEventListener('click', (e) => e.stopPropagation());
                    }
                });

                // Cerrar todas si se hace clic fuera de cualquier card
                document.body.addEventListener('click', (e) => {
                    if (!e.target.closest('.operation-card')) {
                        closeAllCards();
                    }
                });

                // Al hacer logout, también cerrar cards (por si acaso)
                const logoutBtn = document.getElementById('logoutBtn');
                if (logoutBtn) {
                    logoutBtn.addEventListener('click', () => closeAllCards());
                }
            })();
    </script>
</body>
</html>